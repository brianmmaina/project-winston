# Host ports.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Postgres.
POSTGRES_PASSWORD=yourpassword
DATABASE_URL=postgresql+asyncpg://advisor:yourpassword@postgres:5432/commodity_advisor

# Redis.
REDIS_URL=redis://redis:6379

# External APIs.
FRED_API_KEY=your_fred_api_key_here

# Agent pipeline — required for POST /api/agent-analysis.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: enables live web search inside agents. Get a key at app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
# How many top stocks per sector group to surface to each stock agent (default 10).
AGENT_TOP_N_PER_SECTOR=10

# API key for the write endpoints (refresh / retrain).
# Leave empty to disable auth in local dev. In any deployed environment set
# this to a long random string and pass the same value to the frontend build
# (docker-compose forwards it as VITE_API_KEY).
API_KEY=

# Optional knobs.
SCHEDULER_ENABLED=true
TIMEZONE=America/New_York
YFINANCE_DELAY_S=1.0
SENTIMENT_RSS_TIMEOUT_S=15.0
FINBERT_DEVICE=-1
CORS_ORIGINS=*
